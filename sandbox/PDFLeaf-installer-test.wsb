<Configuration>
  <Networking>Enable</Networking>
  <MemoryInMB>4096</MemoryInMB>
  <ClipboardRedirection>Enable</ClipboardRedirection>
  <PrinterRedirection>Disable</PrinterRedirection>
  <AudioInput>Disable</AudioInput>
  <VideoInput>Disable</VideoInput>

  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\Users\jklin\PDFLeaf\src-tauri\target\release\bundle\nsis</HostFolder>
      <SandboxFolder>C:\TestBuilds</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
    <MappedFolder>
      <HostFolder>C:\Users\jklin\PDFLeaf\sandbox</HostFolder>
      <SandboxFolder>C:\SandboxScripts</SandboxFolder>
      <ReadOnly>true</ReadOnly>
    </MappedFolder>
  </MappedFolders>

  <LogonCommand>
    <Command>powershell.exe -NoProfile -ExecutionPolicy Bypass -File C:\SandboxScripts\start-installer-test.ps1</Command>
  </LogonCommand>
</Configuration>
